

@{
    ViewData["Title"] = "Our Services";
}

<div class="container my-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Our Services</h1>
        <p class="text-muted mx-auto" style="max-width: 700px;">
            Providing comprehensive infrastructure, utility protection, and maintenance services across India with a focus on safety and innovation.
        </p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <div class="h1 text-primary mb-3"><i class="bi bi-building"></i></div>
                    <h3 class="h5 fw-bold">Civil Contracting</h3>
                    <p class="card-text text-muted">Specializing in sophisticated construction and general infrastructure works delivered by skilled in-house resources.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <div class="h1 text-warning mb-3"><i class="bi bi-lightning-charge"></i></div>
                    <h3 class="h5 fw-bold">Electrical Services</h3>
                    <p class="card-text text-muted">Expert electrical installation and maintenance for large-scale utility projects and commercial infrastructure.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <div class="h1 text-danger mb-3"><i class="bi bi-fire"></i></div>
                    <h3 class="h5 fw-bold">Fire Safety Systems</h3>
                    <p class="card-text text-muted">Advanced fire-fighting and alarm system installations designed to protect critical assets and human life.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <div class="h1 text-secondary mb-3"><i class="bi bi-shield-lock"></i></div>
                    <h3 class="h5 fw-bold">Manpower & Security</h3>
                    <p class="card-text text-muted">Reliable security services and skilled manpower supply tailored for infrastructure and industrial sites.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <div class="h1 text-success mb-3"><i class="bi bi-tools"></i></div>
                    <h3 class="h5 fw-bold">Utility Protection</h3>
                    <p class="card-text text-muted">Preventive maintenance and inspection services to ensure long-term durability of utility infrastructure.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body text-center p-4">
                    <div class="h1 text-info mb-3"><i class="bi bi-gear-wide-connected"></i></div>
                    <h3 class="h5 fw-bold">Asset Maintenance</h3>
                    <p class="card-text text-muted">Consistent and effective maintenance programs to reduce downtime and improve operational efficiency.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 p-5 bg-dark text-white rounded text-center">
        <h2>Need a specialized solution?</h2>
        <p>Our team is ready to deliver iconic and sophisticated construction work for your next project.</p>
        <a href="/Contact" class="btn btn-primary btn-lg mt-3">Get a Quote</a>
    </div>
</div>