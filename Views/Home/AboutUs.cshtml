@{
}

@{
    ViewData["Title"] = "About Us";
}

<div class="container my-5">
    <div class="row justify-content-center text-center mb-5">
        <div class="col-lg-10">
            <h1 class="display-4 fw-bold text-primary mb-3">Everest Electro-Mech Engineers</h1>
            <p class="lead text-muted mx-auto" style="max-width: 800px;">
                A growing contractor in the infrastructure sector. Our in-house skilled team ensures quality, 
                efficiency, and consistency in project execution. We aim to deliver innovative and reliable 
                services to protect critical infrastructure assets.
            </p>
        </div>
    </div>

    <div class="row g-4 justify-content-center">
        <div class="col-md-5">
            <div class="card h-100 border-0 shadow-sm transition-hover">
                <div class="card-body p-4 border-top border-4 border-primary rounded-top">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-primary text-white rounded-circle p-2 me-3">
                            <i class="bi bi-eye-fill"></i> </div>
                        <h3 class="h4 mb-0 fw-bold">Our Vision</h3>
                    </div>
                    <p class="card-text text-secondary fst-italic">
                        "To build a future-oriented organization delivering excellence beyond expectations."
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card h-100 border-0 shadow-sm transition-hover">
                <div class="card-body p-4 border-top border-4 border-success rounded-top">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-success text-white rounded-circle p-2 me-3">
                            <i class="bi bi-geo-alt-fill"></i>
                        </div>
                        <h3 class="h4 mb-0 fw-bold">Our Mission</h3>
                    </div>
                    <p class="card-text text-secondary fst-italic">
                        "To provide safe, efficient, and high-quality infrastructure services across India."
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .transition-hover {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .transition-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important;
        }
    </style>
}